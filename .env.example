# Copy to .env on a local machine if you need machine-specific defaults.
# Do not commit .env.

# Default bootstrap repository for the project owner.
# Other users should replace this with their own fork/copy, for example:
# REPO_SLUG=your-github-name/Code-Transfer-Station
REPO_SLUG=1563669740/Code-Transfer-Station

# Optional deployment defaults.
BRANCH=main
PROJECT_DIR=$HOME/codex_projects/project
SSH_ALIAS=github-codex-pull
DEPLOY_KEY_PATH=$HOME/.ssh/codex_pull_deploy_key
LOG_DIR=$HOME/codex_pull_logs
STATE_DIR=$HOME/.codex_pull_state
RUN_TIMEOUT=600
INTERVAL_SECONDS=60
START_DAEMON=1
INSTALL_DEPS=1

# Leave empty for read-only deploy key behavior.
# Set to origin only if the deploy key has write access and log push-back is desired.
LOG_PUSH_REMOTE=